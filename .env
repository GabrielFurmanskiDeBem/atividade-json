\PORT=3000\
PERSISTENCE_TYPE=json
Arquivo: src/models/index.js (Factory Pattern)

const persistenceType = process.env.PERSISTENCE_TYPE || 'json';
let ProdutoModel;

if (persistenceType === 'mysql') {
     ProdutoModel = require('./ProdutoModelMySQL');
     console.log(\'Usando persistência: MySQL/MariaDB\');
} else {
     ProdutoModel = require('./ProdutoModel');
     console.log('Usando persistência: JSON (arquivo local)');
}

module.exports = ProdutoModel;
No controller, use:
const ProdutoModel = require('../models');